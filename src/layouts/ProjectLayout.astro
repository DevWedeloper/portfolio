---
import { SITE_TITLE } from '../consts'
import BaseLayout from './BaseLayout.astro'

type Props = {
  title: string
  summary: string
}

const { title, summary } = Astro.props
---

<BaseLayout title={`${SITE_TITLE} | ${title}`} description={summary}>
  <article>
    <slot />
  </article>
</BaseLayout>
